{
	"name": "aimfornan/nan",
	"description": "NaN micro-framework",
	"license": "MIT",
	"autoload": {
		"psr-4": {
			"NaN\\": "src/"
		}
	},
    "require": {
		"php": "^8.4",
		"filp/whoops": "^2.17",
		"guzzlehttp/psr7": "^2.6",
		"league/plates": "^3.5",
		"monolog/monolog": "^3.6",
		"psr/http-server-handler": "^1.0",
		"psr/http-server-middleware": "^1.0",
		"vlucas/phpdotenv": "^5.6",
		"nette/schema": "^1.3",
		"nikic/iter": "^2.4",
		"aimfornan/nan-collections": "dev-main",
		"aimfornan/nan-di": "^0.0.1"
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
	},
	"scripts": {
		"benchmark": "phpbench run benchmarks --report=benchmark",
		"dev": [
			"Composer\\Config::disableProcessTimeout",
			"php -S localhost:8000 -t examples ./examples/index.php"
		],
		"tests": "pest --display-warnings -v"
	},
	"require-dev": {
		"pestphp/pest": "^4.4",
		"phpbench/phpbench": "^1.5"
	}
}
